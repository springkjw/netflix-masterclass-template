{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@app": ["app"],
      "@app/*": ["app/*"],
      "@components": ["components"],
      "@components/*": ["components/*"],
      "@services": ["services/index.ts"],
      "@services/*": ["services/*"],
      "@hooks": ["hooks"],
      "@hooks/*": ["hooks/*"],
      "@constants": ["constants"],
      "@constants/*": ["constants/*"],
      "@utils": ["utils"],
      "@utils/*": ["utils/*"],
      "@theme": ["theme"],
      "@theme/*": ["theme/*"],
      "@models": ["types"],
      "@models/*": ["types/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
